# Local .terraform directories
**/.terraform/

# .tfstate files (VERY IMPORTANT - contains secrets!)
**/*.tfstate
**/*.tfstate.*

# Crash log files
**/crash.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Variable files with sensitive data
**/*.tfvars
**/*.tfvars.json

key
key.pub